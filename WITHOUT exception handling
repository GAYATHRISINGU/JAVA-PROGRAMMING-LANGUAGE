        int a = scan.nextInt(); 
 
        System.out.println("Enter denominator:"); 
        int b = scan.nextInt(); 
 
        int result = a / b;   // Problem if b = 0 
 
System.out.println("Result = " + result); 
System.out.println("Program Ended Successfully"); 
} 
